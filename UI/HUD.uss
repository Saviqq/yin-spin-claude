/* ── Top bar ─────────────────────────────────────────── */
.top-bar {
    width: 100%;
    height: 10%;
    background-color: rgb(0, 0, 0);
    flex-direction: row;
    align-items: center;
    padding: 20px;
    border-bottom-width: 2px;
    border-bottom-color: rgb(255, 255, 255);
}

/* ── Section wrapper (hearts left, score right) ──────── */
.hud-section {
    height: 100%;
    flex-direction: row;
    flex: 1;
}

.flex-start {
    justify-content: flex-start;
}

.flex-end {
    justify-content: flex-end;
}

.align-center {
    align-items: center;
}

/* ── Hearts ─────────────────────────────────────────── */

.heart {
    width: 48px;
    height: 48px;
    margin-right: 4px;
    -unity-background-scale-mode: scale-to-fit;
}

.heart--filled {
    background-image: url("project://database/Assets/Art/hearth-filled.png");

}

.heart--lost {
    background-image: url("project://database/Assets/Art/hearth-lost.png");
}

/* ── Powerup notification ─────────────────────────────── */
.powerup-label {
    flex-grow: 1;
    font-size: 36px;
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    display: none;
}

/* ── Score icon ──────────────────────────────────────── */

.score-icon {
    width: 64px;
    height: 64px;
    -unity-background-scale-mode: scale-to-fit;
    align-items: center;
    justify-content: center;
}

.score-value {
    font-size: 24px;
    color: rgb(0, 0, 0);
    -unity-text-align: middle-center;
    -unity-font-style: bold;
    position: absolute;
}

/* ── Menu panels (Game over, Pause) ───────────────────────────────── */
.menu-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    align-items: center;
    justify-content: center;
    display: none;
}

.menu-panel {
    width: 360px;
    padding: 48px 40px;
    border-width: 2px;
    border-color: rgb(255, 255, 255);
    background-color: rgb(0, 0, 0);
    align-items: center;
}

.menu-title {
    font-size: 42px;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
    margin-bottom: 36px;
    -unity-font-style: bold;
}

.final-score-label {
    font-size: 24px;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
    margin-bottom: 24px;
    letter-spacing: 2px;
}

.menu-btn {
    width: 220px;
    height: 50px;
    margin-top: 14px;
    background-color: rgb(0, 0, 0);
    border-color: rgb(255, 255, 255);
    border-width: 2px;
    color: rgb(255, 255, 255);
    font-size: 18px;
    -unity-text-align: middle-center;
    cursor: pointer;
}

.menu-btn:hover {
    background-color: rgb(255, 255, 255);
    color: rgb(0, 0, 0);
}

/* ── Footer ─────────────────────────────────────────── */

.footer-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 10%;
    background-color: rgb(0, 0, 0);
    border-top-width: 2px;
    border-top-color: rgb(255, 255, 255);
    flex-direction: row;
    align-items: center;
    justify-content: center;
}

/* One action group: keys + label side by side */
.hint-group {
    flex-direction: row;
    align-items: center;
    margin: 0 16px;
}

/* Single key icon — square, 64×64 display size (scaled from 16px source) */
.key-icon {
    width: 64px;
    height: 64px;
    margin: 4px;
    -unity-background-scale-mode: scale-to-fit;
}

.hint-label {
    font-size: 36px;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-left;
}